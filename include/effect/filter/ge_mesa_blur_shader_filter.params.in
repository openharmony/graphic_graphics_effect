struct [[ge::params(type=MESA_BLUR, name="MESA_BLUR")]] GEMESABlurShaderFilterParams {
    [[ge::prop("MESA_BLUR_RADIUS")]]
    int radius;
    [[ge::prop("MESA_BLUR_GREY_COEF_1")]]
    float greyCoef1;
    [[ge::prop("MESA_BLUR_GREY_COEF_2")]]
    float greyCoef2;
    [[ge::prop("OFFSET_X")]]
    float offsetX;
    [[ge::prop("OFFSET_Y")]]
    float offsetY;
    [[ge::prop("OFFSET_Z")]]
    float offsetZ;
    [[ge::prop("OFFSET_W")]]
    float offsetW;
    [[ge::prop("TILE_MODE")]]
    int tileMode;
    [[ge::prop("WIDTH")]]
    float width;
    [[ge::prop("HEIGHT")]]
    float height;
    [[ge::prop("MESA_BLUR_IS_DIRECTION")]]
    bool isDirection = false;
    [[ge::prop("MESA_BLUR_ANGLE")]]
    float angle = 0.0f;
};
