struct [[ge::params(type=WATER_RIPPLE, name="WATER_RIPPLE")]] GEWaterRippleFilterParams {
    [[ge::prop("PROGRESS")]]
    float progress = 0.0f;
    [[ge::prop("WAVE_NUM")]]
    uint32_t waveCount = 2;
    [[ge::prop("RIPPLE_CENTER_X")]]
    float rippleCenterX = 0.5f;
    [[ge::prop("RIPPLE_CENTER_Y")]]
    float rippleCenterY = 0.7f;
    [[ge::prop("RIPPLE_MODE")]]
    uint32_t rippleMode = 1;
};
