constexpr int ARRAY_SIZE_NINE = 9;

struct [[ge::params(type=GRID_WARP, name="GridWarp")]] GEGridWarpShaderFilterParams {
    [[ge::prop(name="GridWarp_GridPoint", array_accessor_length=9)]]
    std::array<std::pair<float, float>, ARRAY_SIZE_NINE> gridPoints;
    [[ge::prop(name="GridWarp_RotationAngle", array_accessor_length=9)]]
    std::array<std::pair<float, float>, ARRAY_SIZE_NINE> rotationAngles;
};
