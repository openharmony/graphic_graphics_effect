struct [[ge::params(type=LINEAR_GRADIENT_BLUR, name="LINEAR_GRADIENT_BLUR")]] GELinearGradientBlurShaderFilterParams {
    [[ge::prop("BLURRADIUS")]]
    float blurRadius;
    [[ge::prop("FRACTIONSTOPS")]]
    std::vector<std::pair<float, float>> fractionStops;
    [[ge::prop("DIRECTION")]]
    int direction;
    [[ge::prop("GEOWIDTH")]]
    float geoWidth;
    [[ge::prop("GEOHEIGHT")]]
    float geoHeight;
    [[ge::prop("CANVASMAT")]]
    Drawing::Matrix mat;
    [[ge::prop("TRANX")]]
    float tranX;
    [[ge::prop("TRANY")]]
    float tranY;
    [[ge::prop("ISOFFSCREEN")]]
    bool isOffscreenCanvas;
    [[ge::prop("ISRADIUSGRADIENT")]]
    bool isRadiusGradient;
};
