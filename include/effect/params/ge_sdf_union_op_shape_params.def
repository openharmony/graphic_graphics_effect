enum class GESDFUnionOp : uint8_t {
    UNION = 0,
    SMOOTH_UNION,
    MAX = SMOOTH_UNION,
};

struct [[ge::params(type=SDF_UNION_OP, name="SDFUnionOpShape")]] GESDFUnionOpShapeParams {
    [[ge::prop("SDFSmoothUnionOpShape_Spacing")]]
    float spacing = 0.f;
    [[ge::prop("SDFUnionOpShape_ShapeX")]]
    [[ge::prop_alias("SDFSmoothUnionOpShape_ShapeX")]]
    std::shared_ptr<GESDFShaderShape> left;
    [[ge::prop("SDFUnionOpShape_ShapeY")]]
    [[ge::prop_alias("SDFSmoothUnionOpShape_ShapeY")]]
    std::shared_ptr<GESDFShaderShape> right;
    [[ge::prop("SDFUnionOpShape_Type")]]
    GESDFUnionOp op = GESDFUnionOp::SMOOTH_UNION;
};
