struct [[ge::params(type=FRAME_GRADIENT_MASK, name="FrameGradientMask")]] GEFrameGradientMaskParams {
    Vector4f innerBezier;
    Vector4f outerBezier;
    float cornerRadius = 0.0f;
    float innerFrameWidth = 0.0f;
    float outerFrameWidth = 0.0f;
    std::pair<float, float> rectWH;
    std::pair<float, float> rectPos;
    [[ge::prop(name="FrameGradientMask_AxialFeatherStrength")]]
    float axialFeatherStrength = 0.0f;
    [[ge::prop(name="FrameGradientMask_AxialCenter")]]
    float axialCenter = 0.5f;
    [[ge::prop(name="FrameGradientMask_AxialCoreWidth")]]
    float axialCoreWidth = 1.0f;
    [[ge::prop(name="FrameGradientMask_AxialDirection")]]
    std::pair<float, float> axialDirection;
    [[ge::prop(name="FrameGradientMask_BoxAngleDeg")]]
    float boxAngleDeg = 0.0f;
};
