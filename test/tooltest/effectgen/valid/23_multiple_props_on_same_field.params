/*
 * Test case for multiple [[ge::prop]] attributes on a single member variable.
 * This tests the scenario where one field needs both:
 * 1. An accessor for the whole array (e.g., BEZIER_WARP_DESTINATION_PATCH)
 * 2. Individual accessors for each element (e.g., BezierWarp_ControlPoint0-11)
 */

constexpr size_t PATCH_POINT_COUNT = 12;

struct [[ge::params(type=BEZIER_WARP, name="BezierWarp")]] BezierWarpParams {
    // Multiple prop attributes on the same field:
    // - One for the whole array accessor (BEZIER_WARP_DESTINATION_PATCH)
    // - One for individual element accessors (BezierWarp_ControlPoint0-11)
    [[ge::prop(name="BEZIER_WARP_DESTINATION_PATCH")]]
    [[ge::prop(name="BezierWarp_ControlPoint", array_accessor_length=12)]]
    std::array<int, PATCH_POINT_COUNT> destinationPatch;

    // Another example with different accessor names
    [[ge::prop(name="COLOR_PALETTE")]]
    [[ge::prop(name="PaletteColor", array_accessor_length=5)]]
    std::array<float, 5> colorPalette;
};
