struct [[ge::params(type=TEST_RANGE, name="TestRange")]] TestRangeParams {
    [[ge::prop(name="PROGRESSX", min=0.0, max=1.0)]]
    float progress = 0.0f;

    [[ge::prop(name="RADIUSX", min=0.0)]]
    float radius = 1.0f;

    [[ge::prop(name="INTENSITYX", max=10.0)]]
    float intensity = 5.0f;

    [[ge::prop(name="NORMALIZED_COORDX", min=0.0, max=1.0)]]
    Vector2f coord = {0.5f, 0.5f};

    [[ge::prop(name="POSITIONX", min=0.0, max=10.0)]]
    Vector3f position = {1.0f, 1.0f, 1.0f};

    [[ge::prop(name="COLORX", min=0.0, max=1.0)]]
    Vector4f color = {1.0f, 1.0f, 1.0f, 1.0f};

    [[ge::prop(name="KBSX", min={0.0, 0.0, -1.0}, max={10.0, 10.0, 1.0})]]
    Vector3f kbs = {1.0f, 1.0f, 0.0f};

    [[ge::prop(name="ASYMMETRICX", min={0.0, 0.0}, max={1.0, 2.0})]]
    Vector2f asymmetric = {0.5f, 1.0f};

    [[ge::prop(name="COUNTX", min=0, max=100)]]
    int count = 50;

    [[ge::prop(name="OFFSETX", min=-50.0, max=50.0)]]
    float offset = 0.0f;
};
