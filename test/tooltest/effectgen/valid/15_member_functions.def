/*
 * Valid: Struct with member functions (should only parse data fields)
 */

struct [[ge::params(type=TEST_MEMBER_FUNCS, name="TestMemberFuncs")]] TestMemberFuncsParams {
    float value1;
    int value2;

    // Member function - should be ignored
