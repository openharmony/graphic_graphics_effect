/*
 * Valid: C++11 raw string literals
 */

struct [[ge::params(type=TEST_RAW_STRINGS, name="TestRawStrings")]] TestRawStringsParams {
    std::string basic = R"(raw string)";
    std::string withTabs = R"(a\tb)";
    std::string withQuotes = R"(He said "Hello")";
    std::string withNewlines = R"(line1
line2
line3)";
    std::string customDelimiter1 = R"##(<#> )##";
    std::string customDelimiter2 = R"delimiter(Contains "delimiter" string)delimiter";
    std::string multilineWithDelimiter = R"JSON({
    "key": "value",
    "nested": {
        "array": [1, 2, 3]
    }
})JSON";
    std::string emptyRaw = R"()";
    std::string backslashPath = R"(C:\Users\Test\file.txt)";
    std::string regexPattern = R"(\w+@\w+\.\w+)";
    std::string htmlContent = R"html(<div class="container">Content</div>)html";
};
