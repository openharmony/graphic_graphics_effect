/*
 * Test case with ge::prop attribute without explicit name (shorthand form)
 */

struct [[ge::params(type=TEST_RANGE_NO_PROP, name="TestRangeNoProp")]] TestRangeNoPropParams {
    [[ge::prop(min=0.0, max=1.0)]]
    float progress = 0.0f;

    [[ge::prop(min=0.0)]]
    float radius = 1.0f;

    [[ge::prop(max=10.0)]]
    float intensity = 5.0f;

    [[ge::prop(min=0.0, max=1.0)]]
    Vector2f coord = {0.5f, 0.5f};

    [[ge::prop(min=0.0, max=10.0)]]
    Vector3f position = {1.0f, 1.0f, 1.0f};

    [[ge::prop(min=0.0, max=1.0)]]
    Vector4f color = {1.0f, 1.0f, 1.0f, 1.0f};

    [[ge::prop(min={0.0, 0.0, -1.0}, max={10.0, 10.0, 1.0})]]
    Vector3f kbs = {1.0f, 1.0f, 0.0f};

    [[ge::prop(min={0.0, 0.0}, max={1.0, 2.0})]]
    Vector2f asymmetric = {0.5f, 1.0f};

    [[ge::prop(min=0, max=100)]]
    int count = 50;

    [[ge::prop(min=-50.0, max=50.0)]]
    float offset = 0.0f;
};
