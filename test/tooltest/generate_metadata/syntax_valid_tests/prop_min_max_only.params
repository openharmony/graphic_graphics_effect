struct [[ge::params(type=PROP_MIN_MAX_ONLY, name="PropMinMaxOnly")]] PropMinMaxOnlyParams {
    // Only min and max, no cast_from
    [[ge::prop(name="TestValue", min=0.0, max=100.0)]]
    float value = 50.0f;

    // Only min, no cast_from
    [[ge::prop(name="TestRadius", min=0.0)]]
    float radius = 1.0f;

    // Only max, no cast_from
    [[ge::prop(name="TestIntensity", max=10.0)]]
    float intensity = 5.0f;

    // Vector min/max with arrays
    [[ge::prop(name="TestVector", min={0.0, 0.0, -1.0}, max={10.0, 10.0, 1.0})]]
    Vector3f vector = {1.0f, 1.0f, 0.0f};

    // Mixed: uniform min, array max
    [[ge::prop(name="TestMixed", min={0.0, 0.0}, max={1.0, 2.0})]]
    Vector2f mixed = {0.5f, 1.0f};
};
