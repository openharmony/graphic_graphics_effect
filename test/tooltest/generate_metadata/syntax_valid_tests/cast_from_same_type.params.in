struct [[ge::params(type=CAST_FROM_SAME_TYPE, name="CastFromSameType")]] TestCastFromSameTypeParams {
    // Invalid: cast_from type equals field type (Drawing::Path)
    [[ge::prop(name="PATH_FIELD", cast_from="Drawing::Path")]]
    Drawing::Path path;
    // Invalid: cast_from type equals field type after alias resolution (int == int32_t)
    [[ge::prop(name="INT_VALUE", cast_from="int")]]
    int32_t intValue = 0;
    // Valid: cast_from with different type (should not trigger error)
    [[ge::prop(name="FLOAT_VALUE", cast_from="int32_t")]]
    float floatValue = 0.0f;
};
