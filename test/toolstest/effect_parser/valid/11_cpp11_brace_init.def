/*
 * Test case for C++11 brace initialization syntax
 * Includes:
 * - Empty braces (value initialization): int a{};
 * - Single value braces: double b{0.6f};
 * - Nested braces: std::array<int, 2> arr{{1, 2}};
 */

struct [[ge::params(type=TEST_CPP11_BRACE, name="TestCpp11Brace")]] TestCpp11BraceParams {
    // Empty brace initialization (value initialization)
    int emptyInt{};
    float emptyFloat{};
    double emptyDouble{};
    bool emptyBool{};

    // Single value brace initialization
    int singleInt{42};
    float singleFloat{3.14f};
    double singleDouble{2.718};
    bool singleBool{true};

    // Mixed traditional and C++11 brace syntax
    int tradInit = 0;
    int braceInit{0};

    // Brace init with string
    std::string emptyStr{};
    std::string helloStr{"Hello, World!"};

    // Complex types with braces
    std::shared_ptr<GEShaderMask> mask{nullptr};
    std::array<int, 3> arr{1, 2, 3};
    Vector2f vec2{1.0f, 2.0f};

    // Nested braces (initializer lists within initializer lists)
    std::vector<std::pair<int, float>> pairs{{1, 1.0f}, {2, 2.0f}};
};
